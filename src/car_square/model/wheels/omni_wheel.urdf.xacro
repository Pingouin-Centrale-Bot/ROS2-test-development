<?xml version="1.0"?>
<robot xmlns:xacro="http://www.ros.org/wiki/xacro">

  <xacro:include filename="$(find car_square)/model/parameters.xacro"/>

  <!-- ========== MACRO ROLLER ========== -->
  <xacro:macro name="roller" params="prefix parent idx angle1 angle2 wheel_radius wheel_width roller_radius roller_length">

    <link name="${prefix}_roller_${idx}">
      <inertial>
        <mass value="0.02"/>
        <inertia ixx="1e-6" iyy="1e-6" izz="1e-6" iyz="0" ixy="0" ixz="0"/>
      </inertial>
      <collision>
        <origin xyz="0 0 0" rpy="1.571 0 0"/>
        <geometry>
          <mesh filename="file://$(find car_square)/meshes/roller.stl" scale="${wheel_radius*61.5384615385} ${wheel_radius*61.5384615385} ${wheel_radius*61.5384615385}"/>
        </geometry>
        <contact_coefficients mu="1.0" kp="0.0" kd="1000.0" />
      </collision>
      <visual>
        <origin xyz="0 0 0" rpy="1.571 0 0"/>
        <geometry>
          <mesh filename="file://$(find car_square)/meshes/roller.stl" scale="${wheel_radius*61.5384615385} ${wheel_radius*61.5384615385} ${wheel_radius*61.5384615385}"/>
        </geometry>
        <material name="white"/>
      </visual>
    </link>

    <link name="${prefix}_roller_neighbor_${idx}">
      <inertial>
        <mass value="0.02"/>
        <inertia ixx="1e-6" iyy="1e-6" izz="1e-6" iyz="0" ixy="0" ixz="0"/>
      </inertial>
      <collision>
        <origin xyz="0 0 0" rpy="1.571 0 0"/>
        <geometry>
          <mesh filename="file://$(find car_square)/meshes/roller.stl" scale="${wheel_radius*61.5384615385} ${wheel_radius*61.5384615385} ${wheel_radius*61.5384615385}"/>
        </geometry>
        <contact_coefficients mu="1.0" kp="0.0" kd="1000.0" />
      </collision>
      <visual>
        <origin xyz="0 0 0" rpy="1.571 0 0"/>
        <geometry>
          <mesh filename="file://$(find car_square)/meshes/roller.stl" scale="${wheel_radius*61.5384615385} ${wheel_radius*61.5384615385} ${wheel_radius*61.5384615385}"/>
        </geometry>
        <material name="white"/>
      </visual>
    </link>

    <joint name="${prefix}_roller_${idx}_joint" type="continuous">
      <parent link="${parent}"/>
      <child link="${prefix}_roller_${idx}"/>
      <origin
        xyz="${(wheel_radius - roller_radius) * cos(angle1)} ${-wheel_width/2} ${(wheel_radius - roller_radius) * sin(angle1)}"
        rpy="${3*pi/2 - angle1} 0 1.5708"/>
      <axis xyz="0 1 0"/>
      <dynamics damping="5.0" friction="1.0"/>
      <limit effort="1.0" velocity="10"/>
    </joint>

    <joint name="${prefix}_roller_neighbor_${idx}_joint" type="continuous">
      <parent link="${parent}"/>
      <child link="${prefix}_roller_neighbor_${idx}"/>
      <origin
        xyz="${(wheel_radius - roller_radius) * cos(angle2)} ${wheel_width/2} ${(wheel_radius - roller_radius) * sin(angle2)}"
        rpy="${3*pi/2 - angle2} 0 1.5708"/>
      <axis xyz="0 1 0"/>
      <dynamics damping="5.0" friction="1.0"/>
      <limit effort="1.0" velocity="10"/>
    </joint>

  </xacro:macro>


  <!-- ========== RÉCURSION ========== -->
  <xacro:macro name="roller_loop"
               params="prefix parent idx count wheel_radius wheel_width roller_radius roller_length">

    <xacro:if value="${idx &lt; count}">
      <xacro:property name="angle1" value="${2 * pi * idx / count}"/>
      <xacro:property name="angle2" value="${2 * pi * idx / count + pi / count}"/>

      <xacro:roller
        prefix="${prefix}" parent="${parent}" idx="${idx}"
        angle1="${angle1}" angle2="${angle2}"
        wheel_radius="${wheel_radius}" wheel_width="${wheel_width}"
        roller_radius="${roller_radius}" roller_length="${roller_length}"/>

      <xacro:roller_loop
        prefix="${prefix}" parent="${parent}" idx="${idx + 1}" count="${count}"
        wheel_radius="${wheel_radius}" wheel_width="${wheel_width}"
        roller_radius="${roller_radius}" roller_length="${roller_length}"/>
    </xacro:if>

  </xacro:macro>


  <!-- ========== OMNI WHEEL COMPLETE ========== -->
  <xacro:macro name="omni_wheel" params="prefix parent xyz rpy">

    <link name="${prefix}_hub">
      <inertial>
        <origin rpy="1.5708 0 0"/>
        <mass value="1.0"/>
        <inertia ixx="0.0001" iyy="0.0001" izz="0.0001" ixy="0" ixz="0" iyz="0"/>
      </inertial>
      <visual>
        <origin xyz="0 0 0" rpy="0 0 1.571"/>
        <geometry>
          <mesh filename="file://$(find car_square)/meshes/rim.stl" scale="${wheel_radius*61.5384615385} ${wheel_radius*61.5384615385} ${wheel_radius*61.5384615385}"/>
        </geometry>
        <material name="blue"/>
      </visual>
      <collision>
        <origin xyz="0 0 0" rpy="0 0 1.571"/>
        <geometry>
          <mesh filename="file://$(find car_square)/meshes/rim.stl" scale="${wheel_radius*61.5384615385} ${wheel_radius*61.5384615385} ${wheel_radius*61.5384615385}"/>
        </geometry>
      </collision>
    </link>

    <joint name="${prefix}_joint" type="continuous">
      <parent link="${parent}"/>
      <child link="${prefix}_hub"/>
      <origin xyz="${xyz}" rpy="${rpy}"/>
      <axis xyz="0 1 0"/>
      <dynamics damping="1.0" friction="0.5"/>
    </joint>

    <xacro:roller_loop
      prefix="${prefix}" parent="${prefix}_hub"
      idx="0" count="${roller_count}"
      wheel_radius="${wheel_radius}" wheel_width="${wheel_width}"
      roller_radius="${roller_radius}" roller_length="${roller_length}"/>

  </xacro:macro>

</robot>